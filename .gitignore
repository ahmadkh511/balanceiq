local_settings.py
db.sqlite3
db.sqlite3-journal
staticfiles/       # مجلد تجميع الملفات الثابتة (يُنشأ بأمر collectstatic في الإنتاج)
media/             # ملفات وصور المستخدمين المرفوعة (يُفضل عدم رفعها على GitHub لتقليل الحجم)

